page {
  min-height: 100%;
  background: linear-gradient(160deg, #fff8e8 0%, #e9f8f2 52%, #ffeef0 100%);
  color: #243035;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Microsoft YaHei", sans-serif;
}

button {
  padding: 0;
  margin: 0;
  border: 0;
  background: transparent;
  color: inherit;
  font: inherit;
}

button::after {
  border: 0;
}
