.app-shell {
  width: 100%;
  min-height: 100vh;
  padding: max(24rpx, env(safe-area-inset-top)) 24rpx max(24rpx, env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.topbar {
  display: grid;
  grid-template-columns: 168rpx 1fr 168rpx;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.brand {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 900;
  color: #284048;
}

.mode-pill {
  min-height: 78rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.76);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 900;
  box-shadow: 0 14rpx 36rpx rgba(52, 63, 66, 0.08);
}

.mode-pill.active {
  background: #243035;
  color: #fffdf6;
}

.kid-view {
  display: flex;
  min-height: calc(100vh - 130rpx);
  flex-direction: column;
  gap: 18rpx;
}

.star-row {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 52rpx;
  gap: 10rpx;
  color: #b8aa86;
  font-weight: 900;
}

.star {
  font-size: 42rpx;
}

.star.filled {
  color: #ffc83d;
}

.star-count {
  font-size: 28rpx;
}

.mode-tabs {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8rpx;
  padding: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.68);
}

.mode-tabs button {
  min-height: 70rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.mode-tabs .active {
  background: #fff;
  color: #db5a3f;
  box-shadow: 0 10rpx 28rpx rgba(66, 78, 80, 0.1);
}

.word-stage {
  position: relative;
  display: flex;
  min-height: 520rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  overflow: hidden;
  border-radius: 56rpx;
  box-shadow: 0 34rpx 70rpx rgba(63, 72, 75, 0.16);
}

.sun {
  background: linear-gradient(145deg, #ffe47d, #ffb85f);
}

.sky {
  background: linear-gradient(145deg, #9fdcff, #64b8ee);
}

.mint {
  background: linear-gradient(145deg, #a8ecd7, #5fcfb5);
}

.rose {
  background: linear-gradient(145deg, #ffc5d2, #ff8f93);
}

.category {
  position: absolute;
  top: 32rpx;
  left: 32rpx;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.62);
  font-size: 26rpx;
  font-weight: 900;
}

.visual {
  font-size: 176rpx;
  line-height: 1;
}

.word {
  color: #fffdf6;
  font-size: 92rpx;
  font-weight: 950;
  line-height: 1;
  text-shadow: 0 8rpx 24rpx rgba(44, 55, 58, 0.22);
}

.hint {
  color: rgba(36, 48, 53, 0.74);
  font-size: 34rpx;
  font-weight: 900;
}

.tap-cue {
  position: absolute;
  right: 28rpx;
  bottom: 28rpx;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.68);
  font-size: 24rpx;
  font-weight: 900;
}

.action-grid,
.choice-grid {
  display: grid;
  gap: 18rpx;
}

.primary-action,
.record-button,
.playback-button {
  min-height: 122rpx;
  border-radius: 32rpx;
  background: #243035;
  color: #fffdf6;
  font-size: 38rpx;
  font-weight: 950;
  box-shadow: 0 18rpx 34rpx rgba(36, 48, 53, 0.16);
}

.visual-grid {
  grid-template-columns: repeat(3, 1fr);
}

.choice-card {
  min-height: 160rpx;
  border-radius: 32rpx;
  font-size: 76rpx;
  box-shadow: 0 14rpx 28rpx rgba(63, 72, 75, 0.12);
}

.word-grid {
  grid-template-columns: repeat(3, 1fr);
}

.word-choice {
  min-height: 104rpx;
  border-radius: 28rpx;
  background: #fff;
  color: #243035;
  font-size: 32rpx;
  font-weight: 950;
  box-shadow: 0 12rpx 24rpx rgba(63, 72, 75, 0.1);
}

.record-panel {
  display: grid;
  gap: 16rpx;
}

.record-button.recording {
  background: #db5a3f;
}

.playback-button {
  background: #fff;
  color: #243035;
}

.record-note {
  text-align: center;
  color: rgba(36, 48, 53, 0.7);
  font-size: 26rpx;
  font-weight: 800;
}

.praise-bubble {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  min-height: 86rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #db5a3f;
  font-size: 32rpx;
  font-weight: 950;
  box-shadow: 0 14rpx 34rpx rgba(66, 78, 80, 0.1);
}

.bottom-controls {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
  margin-top: auto;
}

.bottom-controls button {
  min-height: 108rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.88);
  font-size: 58rpx;
  font-weight: 900;
}

.bottom-controls .home-button {
  background: #ffcf45;
  color: #243035;
}

.parent-view {
  height: calc(100vh - 124rpx);
}

.parent-hero,
.panel {
  margin-bottom: 22rpx;
  padding: 26rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.86);
  box-shadow: 0 14rpx 34rpx rgba(66, 78, 80, 0.08);
}

.parent-hero {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  background: #243035;
  color: #fffdf6;
}

.eyebrow {
  color: #ffcf45;
  font-size: 24rpx;
  font-weight: 900;
}

.hero-title {
  font-size: 42rpx;
  font-weight: 950;
}

.hero-copy {
  color: rgba(255, 253, 246, 0.8);
  font-size: 28rpx;
  line-height: 1.45;
}

.check-button {
  min-height: 82rpx;
  margin-top: 10rpx;
  border-radius: 24rpx;
  background: #ffcf45;
  color: #243035;
  font-size: 30rpx;
  font-weight: 950;
}

.check-button.done {
  background: #a8ecd7;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-bottom: 22rpx;
}

.metric {
  display: flex;
  min-height: 112rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.86);
  font-size: 24rpx;
  font-weight: 900;
}

.metric text:first-child {
  font-size: 38rpx;
}

.panel-head {
  display: grid;
  grid-template-columns: 72rpx 1fr 72rpx;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 32rpx;
  font-weight: 950;
  text-align: center;
}

.panel-head button {
  min-height: 64rpx;
  border-radius: 20rpx;
  background: #f4f6f4;
  font-size: 42rpx;
}

.week-row,
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.week-row {
  margin-bottom: 10rpx;
  color: rgba(36, 48, 53, 0.54);
  font-size: 22rpx;
  font-weight: 900;
  text-align: center;
}

.day-cell {
  display: flex;
  min-height: 70rpx;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  border-radius: 18rpx;
  background: #f4f6f4;
  font-size: 24rpx;
  font-weight: 900;
}

.day-cell.today {
  outline: 4rpx solid #ffcf45;
}

.day-cell.checked {
  background: #a8ecd7;
}

.section-title {
  margin-bottom: 18rpx;
  font-size: 32rpx;
  font-weight: 950;
}

.plan-row {
  display: grid;
  grid-template-columns: 230rpx 1fr;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 2rpx solid rgba(36, 48, 53, 0.07);
}

.plan-date,
.plan-theme {
  display: block;
  font-size: 24rpx;
  font-weight: 900;
}

.plan-date {
  color: rgba(36, 48, 53, 0.58);
}

.plan-words {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.plan-words text {
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: #f4f6f4;
  font-size: 23rpx;
  font-weight: 900;
}

.library-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
}

.library-card {
  display: flex;
  min-height: 188rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 26rpx;
  color: #243035;
}

.library-visual {
  font-size: 56rpx;
}

.library-word {
  color: #fffdf6;
  font-size: 32rpx;
  font-weight: 950;
}

.library-cn {
  font-size: 24rpx;
  font-weight: 900;
}
